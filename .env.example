# ============================================================
# Hunar.pk — Environment Variables
# Copy this file to `.env` (local dev) or set these in your
# hosting platform (Vercel / Railway / Render) dashboard.
# ============================================================

# ---------- DATABASE ----------
# PostgreSQL connection string.
# For Supabase: Project Settings → Database → Connection string → URI
# Format: postgresql://postgres:YOUR_PASSWORD@db.xxxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxxx.supabase.co:5432/postgres

# ---------- AUTH ----------
# Random 32+ character string used to sign JWT session cookies.
# Generate one locally with:  openssl rand -hex 32
# NEVER commit the real value — only this example placeholder.
AUTH_SECRET=replace-with-a-long-random-string-min-32-chars

# ---------- ADMIN PANEL ----------
# Password required to access the /admin panel (separate from user login).
ADMIN_PASSWORD=BA56CR7VK18

# ---------- OPTIONAL ----------
# Node environment (set to "production" on hosting platforms)
# NODE_ENV=production
